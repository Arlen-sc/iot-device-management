{
  "id": "scenario_flow",
  "name": "Camera Device Data Flow",
  "nodes": [
    {
      "id": "start",
      "name": "Start",
      "type": "START",
      "nextNodeId": "tcp_camera"
    },
    {
      "id": "tcp_camera",
      "name": "Get Camera Data",
      "type": "TCP_CLIENT",
      "config": {
        "host": "127.0.0.1",
        "port": 8888,
        "readMode": "RAW",
        "timeout": 5000,
        "outputVariable": "cameraRaw"
      },
      "nextNodeId": "process_camera_data"
    },
    {
      "id": "process_camera_data",
      "name": "Hex to Dec Array",
      "type": "SCRIPT",
      "config": {
        "operations": [
          { "op": "HEX_STRING_TO_DEC_ARRAY", "source": "cameraRaw", "target": "rs" },
          { "op": "ARRAY_LENGTH", "source": "rs", "target": "rs_len" }
        ]
      },
      "nextNodeId": "check_length"
    },
    {
      "id": "check_length",
      "name": "Check Length > 6",
      "type": "CONDITION",
      "config": {
        "branches": [
          {
            "name": "Valid Length",
            "condition": { "left": "rs_len", "operator": ">=", "right": 6 },
            "nextNodeId": "start_tcp_server"
          }
        ],
        "defaultNextNodeId": "end"
      }
    },
    {
      "id": "start_tcp_server",
      "name": "Start TCP Server",
      "type": "TCP_SERVER",
      "config": {
        "port": 9999,
        "operation": "START"
      },
      "nextNodeId": "prepare_broadcast"
    },
    {
      "id": "prepare_broadcast",
      "name": "Prepare Broadcast Data",
      "type": "SCRIPT",
      "config": {
        "operations": [
          { "op": "ARRAY_SLICE", "source": "rs", "target": "rs_6", "params": { "start": 0, "end": 6 } },
          { "op": "JSON_BUILD", "target": "json_str", "params": { "fields": { "data": "${rs_6}", "type": "camera" } } },
          { "op": "STRING_TO_HEX", "source": "json_str", "target": "json_hex" }
        ]
      },
      "nextNodeId": "broadcast_data"
    },
    {
      "id": "broadcast_data",
      "name": "Broadcast JSON",
      "type": "TCP_SERVER",
      "config": {
        "port": 9999,
        "operation": "BROADCAST",
        "sendData": "${json_hex}",
        "sendHex": true
      },
      "nextNodeId": "receive_tcp"
    },
    {
      "id": "receive_tcp",
      "name": "Receive TCP Data",
      "type": "TCP_SERVER",
      "config": {
        "port": 9999,
        "operation": "RECEIVE",
        "timeout": 10000,
        "outputVariable": "clientData"
      },
      "nextNodeId": "check_command"
    },
    {
      "id": "check_command",
      "name": "Check Command",
      "type": "CONDITION",
      "config": {
        "branches": [
          {
            "name": "Is Start",
            "condition": { "left": "clientData", "operator": "contains", "right": "CMD_START" },
            "nextNodeId": "prepare_device_data"
          }
        ],
        "defaultNextNodeId": "end"
      }
    },
    {
      "id": "prepare_device_data",
      "name": "Prepare Device Data",
      "type": "SCRIPT",
      "config": {
        "operations": [
          { "op": "FORMAT_VALUES", "source": "rs", "target": "v_str", "params": { "prefix": "v", "delimiter": "," } },
          { "op": "STRING_TO_HEX", "source": "v_str", "target": "v_hex" }
        ]
      },
      "nextNodeId": "send_to_device"
    },
    {
      "id": "send_to_device",
      "name": "Send to Device",
      "type": "TCP_CLIENT",
      "config": {
        "host": "127.0.0.1",
        "port": 8889,
        "sendData": "${v_hex}",
        "sendHex": true,
        "readMode": "RAW",
        "outputVariable": "devResp"
      },
      "nextNodeId": "check_device_resp"
    },
    {
      "id": "check_device_resp",
      "name": "Check Device Response",
      "type": "CONDITION",
      "config": {
        "branches": [
          {
            "name": "Has Prefix",
            "condition": { "left": "devResp", "operator": "contains", "right": "AA55" },
            "nextNodeId": "parse_device_resp"
          }
        ],
        "defaultNextNodeId": "end"
      }
    },
    {
      "id": "parse_device_resp",
      "name": "Parse Device Response",
      "type": "SCRIPT",
      "config": {
        "operations": [
          { "op": "STRIP_PREFIX", "source": "devResp", "target": "stripped_hex", "params": { "prefix": "AA55" } },
          { "op": "HEX_TO_STRING", "source": "stripped_hex", "target": "json_payload" },
          { "op": "JSON_PARSE", "source": "json_payload", "target": "final_data" }
        ]
      },
      "nextNodeId": "log_data"
    },
    {
      "id": "log_data",
      "name": "Log Data",
      "type": "LOG",
      "config": {
        "message": "Final data processed: ${final_data}",
        "level": "INFO",
        "saveToDb": true
      },
      "nextNodeId": "push_http"
    },
    {
      "id": "push_http",
      "name": "Push to HTTP",
      "type": "HTTP_REQUEST",
      "config": {
        "method": "GET",
        "url": "http://127.0.0.1:18080/api/test/http-receiver/data?v1=${rs[0]}&v2=${rs[1]}&v3=${rs[2]}&status=${final_data.status}"
      },
      "nextNodeId": "stop_tcp_server"
    },
    {
      "id": "stop_tcp_server",
      "name": "Stop TCP Server",
      "type": "TCP_SERVER",
      "config": {
        "port": 9999,
        "operation": "STOP"
      },
      "nextNodeId": "end"
    },
    {
      "id": "end",
      "name": "End",
      "type": "END"
    }
  ],
  "edges": [
    { "source": "start", "target": "tcp_camera" },
    { "source": "tcp_camera", "target": "process_camera_data" },
    { "source": "process_camera_data", "target": "check_length" },
    { "source": "start_tcp_server", "target": "prepare_broadcast" },
    { "source": "prepare_broadcast", "target": "broadcast_data" },
    { "source": "broadcast_data", "target": "receive_tcp" },
    { "source": "receive_tcp", "target": "check_command" },
    { "source": "prepare_device_data", "target": "send_to_device" },
    { "source": "send_to_device", "target": "check_device_resp" },
    { "source": "parse_device_resp", "target": "log_data" },
    { "source": "log_data", "target": "push_http" },
    { "source": "push_http", "target": "stop_tcp_server" },
    { "source": "stop_tcp_server", "target": "end" }
  ]
}