{
  "nodes": [
    {
      "id": "node_start",
      "type": "START",
      "name": "开始节点",
      "config": {}
    },
    {
      "id": "node_tcp_client_camera",
      "type": "TCP_CLIENT",
      "name": "1.获取摄像机数据",
      "config": {
        "host": "127.0.0.1",
        "port": 9001,
        "readMode": "RAW",
        "outputVariable": "cameraRawHex",
        "waitResponse": true
      }
    },
    {
      "id": "node_script_hex_to_dec",
      "type": "SCRIPT",
      "name": "1.1.16转10进制及数组提取",
      "config": {
        "operations": [
          { "op": "HEX_STRING_TO_DEC_ARRAY", "source": "cameraRawHex", "target": "rs" },
          { "op": "ARRAY_LENGTH", "source": "rs", "target": "rsLen" }
        ]
      }
    },
    {
      "id": "node_condition_check_length",
      "type": "CONDITION",
      "name": "2.判断数据>6",
      "config": {
        "logic": "AND",
        "branches": [
          {
            "name": "Length OK",
            "condition": { "left": "rsLen", "operator": ">", "right": 6 },
            "nextNodeId": "node_script_format_broadcast"
          }
        ],
        "defaultNextNodeId": "node_end"
      }
    },
    {
      "id": "node_script_format_broadcast",
      "type": "SCRIPT",
      "name": "3.加工成固定JSON并转16进制",
      "config": {
        "operations": [
          { "op": "ARRAY_SLICE", "source": "rs", "target": "subArr", "params": { "start": 0, "end": 6 } },
          { "op": "JSON_BUILD", "target": "jsonStr", "params": { "template": "{\"data\": ${subArr}, \"type\": \"camera\"}" } },
          { "op": "STRING_TO_HEX", "source": "jsonStr", "target": "broadcastHex" }
        ]
      }
    },
    {
      "id": "node_tcp_server_start",
      "type": "TCP_SERVER",
      "name": "启动广播服务器",
      "config": {
        "port": 9100,
        "operation": "START"
      }
    },
    {
      "id": "node_delay",
      "type": "DELAY",
      "name": "等待客户端连接",
      "config": {
        "delayMs": 2000
      }
    },
    {
      "id": "node_tcp_server_broadcast",
      "type": "TCP_SERVER",
      "name": "3.1.广播数据",
      "config": {
        "port": 9100,
        "operation": "BROADCAST",
        "sendData": "${broadcastHex}",
        "sendHex": true
      }
    },
    {
      "id": "node_tcp_server_listen",
      "type": "TCP_SERVER",
      "name": "4.监听返回数据",
      "config": {
        "port": 9100,
        "operation": "RECEIVE",
        "outputVariable": "serverReceived",
        "timeout": 5000
      }
    },
    {
      "id": "node_condition_check_command",
      "type": "CONDITION",
      "name": "5.是否为指定指令",
      "config": {
        "logic": "AND",
        "branches": [
          {
            "name": "Cmd OK",
            "condition": { "left": "serverReceived", "operator": "equals_trim", "right": "CMD_PROCEED" },
            "nextNodeId": "node_script_format_device"
          }
        ],
        "defaultNextNodeId": "node_end"
      }
    },
    {
      "id": "node_script_format_device",
      "type": "SCRIPT",
      "name": "6.转换为v1,v2,v3模式",
      "config": {
        "operations": [
          { "op": "ARRAY_SLICE", "source": "rs", "target": "subArrForDevice", "params": { "start": 0, "end": 3 } },
          { "op": "FORMAT_VALUES", "source": "subArrForDevice", "target": "vMode", "params": { "prefix": "v", "delimiter": "," } },
          { "op": "STRING_TO_HEX", "source": "vMode", "target": "deviceCmdHex" }
        ]
      }
    },
    {
      "id": "node_tcp_client_device",
      "type": "TCP_CLIENT",
      "name": "6.1.传给另一个设备",
      "config": {
        "host": "127.0.0.1",
        "port": 9002,
        "sendData": "${deviceCmdHex}",
        "sendHex": true,
        "readMode": "LINE",
        "outputVariable": "deviceResponse",
        "waitResponse": true
      }
    },
    {
      "id": "node_condition_check_prefix",
      "type": "CONDITION",
      "name": "检查前缀",
      "config": {
        "logic": "AND",
        "branches": [
          {
            "name": "Prefix OK",
            "condition": { "left": "deviceResponse", "operator": "starts_with", "right": "PREFIX:" },
            "nextNodeId": "node_script_process_device_resp"
          }
        ],
        "defaultNextNodeId": "node_end"
      }
    },
    {
      "id": "node_script_process_device_resp",
      "type": "SCRIPT",
      "name": "6.2.去掉前缀并16转10及JSON",
      "config": {
        "operations": [
          { "op": "STRIP_PREFIX", "source": "deviceResponse", "target": "hexBody", "params": { "prefix": "PREFIX:" } },
          { "op": "HEX_TO_STRING", "source": "hexBody", "target": "jsonStr" },
          { "op": "JSON_PARSE", "source": "jsonStr", "target": "finalDataObj" },
          { "op": "JSON_STRINGIFY", "source": "finalDataObj", "target": "finalData" }
        ]
      }
    },
    {
      "id": "node_log",
      "type": "LOG",
      "name": "7.存储至日志",
      "config": {
        "level": "INFO",
        "message": "Processed final data: ${finalData}"
      }
    },
    {
      "id": "node_http_push",
      "type": "HTTP_REQUEST",
      "name": "8.推送至HTTP",
      "config": {
        "method": "GET",
        "url": "http://127.0.0.1:8890/api/push?data=${finalData}"
      }
    },
    {
      "id": "node_end",
      "type": "END",
      "name": "结束节点",
      "config": {}
    }
  ],
  "edges": [
    { "id": "e1", "source": "node_start", "target": "node_tcp_client_camera" },
    { "id": "e2", "source": "node_tcp_client_camera", "target": "node_script_hex_to_dec" },
    { "id": "e3", "source": "node_script_hex_to_dec", "target": "node_condition_check_length" },
    
    { "id": "e4", "source": "node_condition_check_length", "sourceAnchor": "true", "target": "node_script_format_broadcast" },
    { "id": "e4_f", "source": "node_condition_check_length", "sourceAnchor": "false", "target": "node_end" },
    
    { "id": "e5", "source": "node_script_format_broadcast", "target": "node_tcp_server_start" },
    { "id": "e6", "source": "node_tcp_server_start", "target": "node_delay" },
    { "id": "e6_1", "source": "node_delay", "target": "node_tcp_server_broadcast" },
    { "id": "e7", "source": "node_tcp_server_broadcast", "target": "node_tcp_server_listen" },
    { "id": "e8", "source": "node_tcp_server_listen", "target": "node_condition_check_command" },
    
    { "id": "e10", "source": "node_condition_check_command", "sourceAnchor": "true", "target": "node_script_format_device" },
    { "id": "e10_f", "source": "node_condition_check_command", "sourceAnchor": "false", "target": "node_end" },
    
    { "id": "e11", "source": "node_script_format_device", "target": "node_tcp_client_device" },
    { "id": "e12", "source": "node_tcp_client_device", "target": "node_condition_check_prefix" },
    
    { "id": "e13", "source": "node_condition_check_prefix", "sourceAnchor": "true", "target": "node_script_process_device_resp" },
    { "id": "e13_f", "source": "node_condition_check_prefix", "sourceAnchor": "false", "target": "node_end" },
    
    { "id": "e14", "source": "node_script_process_device_resp", "target": "node_log" },
    { "id": "e15", "source": "node_log", "target": "node_http_push" },
    { "id": "e16", "source": "node_http_push", "target": "node_end" }
  ]
}