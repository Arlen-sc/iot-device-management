{
  "nodes": [
    {
      "id": "n_start",
      "type": "START",
      "name": "流程开始",
      "x": 80,
      "y": 300,
      "config": {
        "name": "流程开始",
        "description": "摄像头数据采集与设备交互主流程",
        "triggerType": "ONCE"
      }
    },
    {
      "id": "n_tcp_camera",
      "type": "TCP_CLIENT",
      "name": "步骤1-获取摄像头数据",
      "x": 300,
      "y": 300,
      "config": {
        "name": "步骤1-获取摄像头数据",
        "host": "127.0.0.1",
        "port": 9001,
        "sendData": "",
        "sendHex": false,
        "waitResponse": true,
        "timeout": 5000,
        "readMode": "LINE",
        "outputVariable": "cameraRawData"
      }
    },
    {
      "id": "n_split_hex",
      "type": "SCRIPT",
      "name": "步骤1b-拆分16进制数据",
      "x": 530,
      "y": 300,
      "config": {
        "name": "步骤1b-拆分并转换",
        "operations": [
          {
            "op": "SPLIT",
            "source": "cameraRawData",
            "target": "hexArray",
            "params": {"delimiter": ","}
          },
          {
            "op": "HEX_ARRAY_TO_DEC",
            "source": "hexArray",
            "target": "rs",
            "params": {}
          },
          {
            "op": "ARRAY_LENGTH",
            "source": "rs",
            "target": "rsLength",
            "params": {}
          }
        ]
      }
    },
    {
      "id": "n_check_length",
      "type": "CONDITION",
      "name": "步骤2-判断数组>=6",
      "x": 780,
      "y": 300,
      "config": {
        "name": "步骤2-判断数组>=6",
        "branches": [
          {
            "name": "满足条件(>=6)",
            "condition": {
              "left": "rsLength",
              "operator": ">=",
              "right": 6
            },
            "nextNodeId": "n_start_server"
          }
        ],
        "defaultNextNodeId": "n_end_fail"
      }
    },
    {
      "id": "n_end_fail",
      "type": "END",
      "name": "不满足条件-结束",
      "x": 780,
      "y": 500,
      "config": {
        "name": "不满足条件-结束",
        "description": "摄像头数据不足6组，流程终止"
      }
    },
    {
      "id": "n_start_server",
      "type": "TCP_SERVER",
      "name": "步骤3a-启动TCP服务器",
      "x": 1030,
      "y": 200,
      "config": {
        "name": "步骤3a-启动TCP服务器",
        "port": 9100,
        "operation": "START",
        "outputVariable": "tcpServerStatus"
      }
    },
    {
      "id": "n_delay_for_clients",
      "type": "DELAY",
      "name": "等待客户端连接",
      "x": 1030,
      "y": 300,
      "config": {
        "name": "等待客户端连接",
        "delayMs": 2000
      }
    },
    {
      "id": "n_build_json",
      "type": "SCRIPT",
      "name": "步骤3b-构建JSON并转进制",
      "x": 1280,
      "y": 300,
      "config": {
        "name": "步骤3b-构建JSON并转进制",
        "operations": [
          {
            "op": "JSON_BUILD",
            "source": null,
            "target": "broadcastJson",
            "params": {
              "fields": {
                "type": "camera_data",
                "d1": "${rs[0]}",
                "d2": "${rs[1]}",
                "d3": "${rs[2]}",
                "d4": "${rs[3]}",
                "d5": "${rs[4]}",
                "d6": "${rs[5]}"
              }
            }
          },
          {
            "op": "STRING_TO_HEX",
            "source": "broadcastJson",
            "target": "broadcastHex",
            "params": {}
          }
        ]
      }
    },
    {
      "id": "n_broadcast",
      "type": "TCP_SERVER",
      "name": "步骤3c-广播给所有连接",
      "x": 1530,
      "y": 300,
      "config": {
        "name": "步骤3c-广播给所有连接",
        "port": 9100,
        "operation": "BROADCAST",
        "sendData": "${broadcastJson}",
        "sendHex": false,
        "outputVariable": "broadcastCount"
      }
    },
    {
      "id": "n_wait_command",
      "type": "TCP_SERVER",
      "name": "步骤4-监听指令",
      "x": 1780,
      "y": 300,
      "config": {
        "name": "步骤4-监听TCP指令",
        "port": 9100,
        "operation": "RECEIVE",
        "timeout": 30000,
        "outputVariable": "receivedCommand"
      }
    },
    {
      "id": "n_check_command",
      "type": "CONDITION",
      "name": "步骤5-判断指令",
      "x": 2030,
      "y": 300,
      "config": {
        "name": "步骤5-判断指令",
        "branches": [
          {
            "name": "匹配ACK_READY",
            "condition": {
              "left": "receivedCommand",
              "operator": "contains",
              "right": "ACK_READY"
            },
            "nextNodeId": "n_format_send"
          },
          {
            "name": "匹配CONFIRM",
            "condition": {
              "left": "receivedCommand",
              "operator": "starts_with",
              "right": "CONFIRM"
            },
            "nextNodeId": "n_format_send"
          }
        ],
        "defaultNextNodeId": "n_wait_command"
      }
    },
    {
      "id": "n_format_send",
      "type": "SCRIPT",
      "name": "步骤6a-格式化v1,v2,v3并转进制",
      "x": 2280,
      "y": 300,
      "config": {
        "name": "步骤6a-格式化并转进制",
        "operations": [
          {
            "op": "FORMAT_VALUES",
            "source": "rs",
            "target": "formattedValues",
            "params": {"prefix": "v", "delimiter": ","}
          },
          {
            "op": "STRING_TO_HEX",
            "source": "formattedValues",
            "target": "sendHexData",
            "params": {}
          }
        ]
      }
    },
    {
      "id": "n_send_device",
      "type": "TCP_CLIENT",
      "name": "步骤6b-发送给设备",
      "x": 2530,
      "y": 300,
      "config": {
        "name": "步骤6b-发送给设备",
        "host": "127.0.0.1",
        "port": 9002,
        "sendData": "${formattedValues}",
        "sendHex": false,
        "waitResponse": true,
        "timeout": 10000,
        "readMode": "LINE",
        "outputVariable": "deviceResponse"
      }
    },
    {
      "id": "n_check_prefix",
      "type": "CONDITION",
      "name": "步骤6c-检查返回前缀",
      "x": 2780,
      "y": 300,
      "config": {
        "name": "步骤6c-检查返回前缀",
        "branches": [
          {
            "name": "包含OK:前缀",
            "condition": {
              "left": "deviceResponse",
              "operator": "starts_with",
              "right": "OK:"
            },
            "nextNodeId": "n_parse_response"
          }
        ],
        "defaultNextNodeId": "n_end_error"
      }
    },
    {
      "id": "n_end_error",
      "type": "END",
      "name": "设备返回异常-结束",
      "x": 2780,
      "y": 500,
      "config": {
        "name": "设备返回异常-结束",
        "description": "设备返回数据不包含预期前缀"
      }
    },
    {
      "id": "n_parse_response",
      "type": "SCRIPT",
      "name": "步骤6d-去前缀转换解析",
      "x": 3030,
      "y": 300,
      "config": {
        "name": "步骤6d-去前缀并解析",
        "operations": [
          {
            "op": "STRIP_PREFIX",
            "source": "deviceResponse",
            "target": "strippedData",
            "params": {"prefix": "OK:"}
          },
          {
            "op": "SPLIT",
            "source": "strippedData",
            "target": "responseHexArray",
            "params": {"delimiter": ","}
          },
          {
            "op": "HEX_ARRAY_TO_DEC",
            "source": "responseHexArray",
            "target": "responseDecArray",
            "params": {}
          },
          {
            "op": "JSON_BUILD",
            "source": null,
            "target": "parsedResult",
            "params": {
              "fields": {
                "status": "success",
                "values": "${responseDecArray}",
                "source": "device_response",
                "originalCommand": "${formattedValues}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "n_log",
      "type": "LOG",
      "name": "步骤7-日志记录",
      "x": 3280,
      "y": 300,
      "config": {
        "name": "步骤7-日志和数据记录",
        "message": "设备交互完成: 摄像头数据=${rs}, 设备返回=${responseDecArray}",
        "dataPath": "parsedResult",
        "logLevel": "INFO",
        "saveToDb": true,
        "outputVariable": "logEntry"
      }
    },
    {
      "id": "n_http_push",
      "type": "HTTP_REQUEST",
      "name": "步骤8-HTTP推送",
      "x": 3530,
      "y": 300,
      "config": {
        "name": "步骤8-HTTP GET推送",
        "method": "GET",
        "url": "http://127.0.0.1:8080/api/test/http-receiver/data?v1=${rs[0]}&v2=${rs[1]}&v3=${rs[2]}&v4=${rs[3]}&v5=${rs[4]}&v6=${rs[5]}&result=${parsedResult}",
        "contentType": "application/json",
        "timeout": 10000,
        "outputVariable": "httpResponse"
      }
    },
    {
      "id": "n_stop_server",
      "type": "TCP_SERVER",
      "name": "清理-停止TCP服务器",
      "x": 3780,
      "y": 300,
      "config": {
        "name": "清理-停止TCP服务器",
        "port": 9100,
        "operation": "STOP",
        "outputVariable": "stopResult"
      }
    },
    {
      "id": "n_end_ok",
      "type": "END",
      "name": "流程完成",
      "x": 4030,
      "y": 300,
      "config": {
        "name": "流程完成",
        "description": "全部步骤执行成功"
      }
    }
  ],
  "edges": [
    {"id": "e_1", "source": "n_start", "sourcePort": "out_0", "target": "n_tcp_camera", "targetPort": "in_0", "label": ""},
    {"id": "e_2", "source": "n_tcp_camera", "sourcePort": "out_0", "target": "n_split_hex", "targetPort": "in_0", "label": ""},
    {"id": "e_3", "source": "n_split_hex", "sourcePort": "out_0", "target": "n_check_length", "targetPort": "in_0", "label": ""},
    {"id": "e_4a", "source": "n_start_server", "sourcePort": "out_0", "target": "n_delay_for_clients", "targetPort": "in_0", "label": ""},
    {"id": "e_4b", "source": "n_delay_for_clients", "sourcePort": "out_0", "target": "n_build_json", "targetPort": "in_0", "label": ""},
    {"id": "e_5", "source": "n_build_json", "sourcePort": "out_0", "target": "n_broadcast", "targetPort": "in_0", "label": ""},
    {"id": "e_6", "source": "n_broadcast", "sourcePort": "out_0", "target": "n_wait_command", "targetPort": "in_0", "label": ""},
    {"id": "e_7", "source": "n_wait_command", "sourcePort": "out_0", "target": "n_check_command", "targetPort": "in_0", "label": ""},
    {"id": "e_8", "source": "n_format_send", "sourcePort": "out_0", "target": "n_send_device", "targetPort": "in_0", "label": ""},
    {"id": "e_9", "source": "n_send_device", "sourcePort": "out_0", "target": "n_check_prefix", "targetPort": "in_0", "label": ""},
    {"id": "e_11", "source": "n_parse_response", "sourcePort": "out_0", "target": "n_log", "targetPort": "in_0", "label": ""},
    {"id": "e_12", "source": "n_log", "sourcePort": "out_0", "target": "n_http_push", "targetPort": "in_0", "label": ""},
    {"id": "e_13", "source": "n_http_push", "sourcePort": "out_0", "target": "n_stop_server", "targetPort": "in_0", "label": ""},
    {"id": "e_14", "source": "n_stop_server", "sourcePort": "out_0", "target": "n_end_ok", "targetPort": "in_0", "label": ""}
  ],
  "variables": [
    {"name": "cameraRawData", "defaultValue": ""},
    {"name": "hexArray", "defaultValue": null},
    {"name": "rs", "defaultValue": null},
    {"name": "rsLength", "defaultValue": 0},
    {"name": "broadcastJson", "defaultValue": ""},
    {"name": "broadcastHex", "defaultValue": ""},
    {"name": "broadcastCount", "defaultValue": 0},
    {"name": "receivedCommand", "defaultValue": ""},
    {"name": "formattedValues", "defaultValue": ""},
    {"name": "sendHexData", "defaultValue": ""},
    {"name": "deviceResponse", "defaultValue": ""},
    {"name": "strippedData", "defaultValue": ""},
    {"name": "responseHexArray", "defaultValue": null},
    {"name": "responseDecArray", "defaultValue": null},
    {"name": "parsedResult", "defaultValue": ""},
    {"name": "logEntry", "defaultValue": null},
    {"name": "httpResponse", "defaultValue": null}
  ]
}
